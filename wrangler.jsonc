{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "featherbench-api",
  "main": "src/index.js",
  "compatibility_date": "2026-05-03",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "observability": {
    "enabled": true
  }
}
