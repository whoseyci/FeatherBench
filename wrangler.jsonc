{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "featherbench",
  "main": "src/index.js",
  "compatibility_date": "2026-05-03",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "durable_objects": {
    "bindings": [
      { "name": "RUN_GATE", "class_name": "RunGate" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["RunGate"] }
  ],
  "observability": {
    "enabled": true
  }
}
